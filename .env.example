# ── App ────────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database — Neon PostgreSQL ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/orderhub?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/orderhub?sslmode=require

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_secure_random_string
JWT_EXPIRES_IN=7d

# ── Better Auth (shared secret — must match frontend) ─────────────────────────
BETTER_AUTH_SECRET=replace_with_openssl_rand_base64_32
